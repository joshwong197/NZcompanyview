{
    "openapi": "3.0.1",
    "info": {
        "title": "Companies Disqualified Director Search",
        "description": "The Companies Disqualified Director Search API provides the facility for searching for disqualified company directors or prohibited company managers by name. See the Companies Register website for more information about [how and why directors may be prohibited](https://companies-register.companiesoffice.govt.nz/help-centre/company-directors/banned-directors/). See [here](./api/companies-disqualified-director-search) for additional information on how to use the API. A separate [API](./api-details#api=companies-entity-role-search-v3) is available for searching for directors and shareholders.",
        "version": "v3"
    },
    "servers": [
        {
            "url": "https://api.business.govt.nz/gateway/companies-office/companies-register/disqualified-directors/v3"
        },
        {
            "url": "https://api.int.mbie.govt.nz/gateway/companies-office/companies-register/disqualified-directors/v3"
        },
        {
            "url": "https://apim.api.int.mbie.govt.nz/gateway/companies-office/companies-register/disqualified-directors/v3"
        }
    ],
    "paths": {
        "/search": {
            "get": {
                "summary": "Search for disqualified directors from companies. Uses query parameters.",
                "description": "This service searches the Companies Register for disqualified Directors in company entities. The search criterion is the name of the (disqualified) person.  Note that the search performed is a 'starts with' style search on first name, last name and middle names.",
                "operationId": "get-search-page-page-page-size-page-size-name-name",
                "parameters": [
                    {
                        "name": "page",
                        "in": "query",
                        "description": "The page in the collection to return, starting at 0. Default is page 0.",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "default": 0
                        }
                    },
                    {
                        "name": "page-size",
                        "in": "query",
                        "description": "The number of items to include in each page returned. Default is 10.",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "default": 10
                        }
                    },
                    {
                        "name": "name",
                        "in": "query",
                        "description": "Name of the person to search for. Note that the search performed is a 'starts with' style search on first name, last name and middle names. Note also that the name to search for must be at least 2 characters long.",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "The list of disqualified directors matching the search criteria.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/SearchResults"
                                },
                                "example": {
                                    "totalResults": 0,
                                    "roles": [
                                        {
                                            "middleName": "Martin",
                                            "lastName": "BLOGGS",
                                            "disqualifiedDirectorId": 12345678,
                                            "addresses": [
                                                {
                                                    "addressLines": [
                                                        "string"
                                                    ],
                                                    "postCode": 1025,
                                                    "countryCode": "NZ",
                                                    "pafId": 580631
                                                }
                                            ],
                                            "associations": {
                                                "associations": [
                                                    {
                                                        "associatedCompanyNumber": 1234567,
                                                        "associatedCompanyName": "ACME LIMITED",
                                                        "associatedCompanyNzbn": 123456789012,
                                                        "associatedCompanyStatusCode": 80
                                                    }
                                                ]
                                            },
                                            "disqualificationCriteria": {
                                                "criteria": [
                                                    {
                                                        "startDate": "2015-08-02",
                                                        "criteria": "Section 299 Insolvency Act 2006",
                                                        "endDate": "2019-08-10",
                                                        "comments": "Information received from ASIC. This person is banned in Australia."
                                                    }
                                                ]
                                            },
                                            "firstName": "Jo",
                                            "aliases": {
                                                "aliases": [
                                                    "BLOGGS, Jo Martin"
                                                ]
                                            }
                                        }
                                    ],
                                    "pageSize": 0,
                                    "currentPage": 0
                                }
                            },
                            "applicaiton/xml": {
                                "schema": {
                                    "$ref": "#/components/schemas/SearchResults"
                                },
                                "example": "<SearchResults> <totalResults>0</totalResults> <roles> <middleName>Martin</middleName> <lastName>BLOGGS</lastName> <disqualifiedDirectorId>12345678</disqualifiedDirectorId> <addresses> <addressLines>string</addressLines> <postCode>1025</postCode> <countryCode>NZ</countryCode> <pafId>580631</pafId> </addresses> <associations> <associations> <associatedCompanyNumber>1234567</associatedCompanyNumber> <associatedCompanyName>ACME LIMITED</associatedCompanyName> <associatedCompanyNzbn>123456789012</associatedCompanyNzbn> <associatedCompanyStatusCode>80</associatedCompanyStatusCode> </associations> </associations> <disqualificationCriteria> <criteria> <startDate>2015-08-02</startDate> <criteria>Section 299 Insolvency Act 2006</criteria> <endDate>2019-08-10</endDate> <comments>Information received from ASIC. This person is banned in Australia.</comments> </criteria> </disqualificationCriteria> <firstName>Jo</firstName> <aliases> <aliases>BLOGGS, Jo Martin</aliases> </aliases> </roles> <pageSize>0</pageSize> <currentPage>0</currentPage> </SearchResults>"
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid request parameters.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorDescription"
                                },
                                "example": {
                                    "message": "An unexpected error occured servicing the request.",
                                    "statusCode": 400,
                                    "error": true
                                }
                            },
                            "applicaiton/xml": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorDescription"
                                },
                                "example": "<ErrorDescription> <message>An unexpected error occured servicing the request.</message> <statusCode>400</statusCode> <error>True</error> </ErrorDescription>"
                            }
                        }
                    },
                    "401": {
                        "description": "The requester is not authenticated.",
                        "content": {
                            "application/json": {},
                            "applicaiton/xml": {}
                        }
                    },
                    "403": {
                        "description": "The requester is not authorised for this API.",
                        "content": {
                            "application/json": {},
                            "applicaiton/xml": {}
                        }
                    },
                    "500": {
                        "description": "An unexpected internal server error occurred.",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorDescription"
                                },
                                "example": {
                                    "message": "An unexpected error occured servicing the request.",
                                    "statusCode": 400,
                                    "error": true
                                }
                            },
                            "applicaiton/xml": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorDescription"
                                },
                                "example": "<ErrorDescription> <message>An unexpected error occured servicing the request.</message> <statusCode>400</statusCode> <error>True</error> </ErrorDescription>"
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "DisqualifiedDirector": {
                "required": [
                    "firstName",
                    "lastName",
                    "aliases",
                    "associations",
                    "disqualificationCriteria"
                ],
                "properties": {
                    "middleName": {
                        "type": "string",
                        "description": "Middle name(s) of the person",
                        "example": "Martin"
                    },
                    "lastName": {
                        "type": "string",
                        "description": "The last name of the person",
                        "example": "BLOGGS"
                    },
                    "disqualifiedDirectorId": {
                        "type": "string",
                        "description": "The identifier for the qualified director",
                        "example": "12345678"
                    },
                    "addresses": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/Address"
                        }
                    },
                    "associations": {
                        "type": "object",
                        "properties": {
                            "associations": {
                                "type": "array",
                                "items": {
                                    "required": [
                                        "associatedCompanyName",
                                        "associatedCompanyNumber",
                                        "associatedCompanyNzbn",
                                        "associatedCompanyStatusCode"
                                    ],
                                    "type": "object",
                                    "properties": {
                                        "associatedCompanyNumber": {
                                            "type": "string",
                                            "description": "Company number",
                                            "example": "1234567"
                                        },
                                        "associatedCompanyName": {
                                            "type": "string",
                                            "description": "Company name",
                                            "example": "ACME LIMITED"
                                        },
                                        "associatedCompanyNzbn": {
                                            "type": "string",
                                            "description": "The NZBN of the company",
                                            "example": "123456789012"
                                        },
                                        "associatedCompanyStatusCode": {
                                            "type": "string",
                                            "description": "A code that identifies the current company status",
                                            "example": "80"
                                        }
                                    }
                                },
                                "description": "List of associations the person has with companies"
                            }
                        },
                        "description": "Associations (unfortunate double depth retained for backwards compatibility)"
                    },
                    "disqualificationCriteria": {
                        "type": "object",
                        "properties": {
                            "criteria": {
                                "type": "array",
                                "items": {
                                    "required": [
                                        "startDate"
                                    ],
                                    "type": "object",
                                    "properties": {
                                        "startDate": {
                                            "type": "string",
                                            "description": "Start date of the disqualification",
                                            "format": "date",
                                            "example": "2015-08-02"
                                        },
                                        "criteria": {
                                            "type": "string",
                                            "description": "(Optional) criterion for the disqualification",
                                            "example": "Section 299 Insolvency Act 2006"
                                        },
                                        "endDate": {
                                            "type": "string",
                                            "description": "(Optional) end date of the disqualification",
                                            "format": "date",
                                            "example": "2019-08-10"
                                        },
                                        "comments": {
                                            "type": "string",
                                            "description": "(Optional) comments date of the disqualification",
                                            "example": "Information received from ASIC. This person is banned in Australia."
                                        }
                                    }
                                },
                                "description": "List of disqualification criteria"
                            }
                        },
                        "description": "Disqualification criteria (unfortunate double depth retained for backwards compatibility)"
                    },
                    "firstName": {
                        "type": "string",
                        "description": "The first name of the person",
                        "example": "Jo"
                    },
                    "aliases": {
                        "type": "object",
                        "properties": {
                            "aliases": {
                                "type": "array",
                                "items": {
                                    "type": "string",
                                    "example": "BLOGGS, Jo Martin"
                                },
                                "description": "List of aliases for the person in format 'lastName, firstName middleName(s)'"
                            }
                        },
                        "description": "Aliases (unfortunate double depth retained for backwards compatibility)"
                    }
                },
                "description": "Information about a disqualified director"
            },
            "ErrorDescription": {
                "required": [
                    "error",
                    "statusCode",
                    "message"
                ],
                "properties": {
                    "message": {
                        "type": "string",
                        "description": "Text explaining the message.",
                        "example": "An unexpected error occured servicing the request."
                    },
                    "statusCode": {
                        "type": "integer",
                        "description": "Status code for the message.",
                        "example": 400
                    },
                    "error": {
                        "type": "boolean",
                        "description": "Boolean to indicate whether the message is an error or not.",
                        "example": true
                    }
                },
                "description": "Representation of generic error response"
            },
            "SearchResults": {
                "required": [
                    "currentPage",
                    "pageSize",
                    "totalResults",
                    "roles"
                ],
                "properties": {
                    "totalResults": {
                        "minimum": 0,
                        "type": "integer",
                        "description": "The total number of results/items in this collection"
                    },
                    "roles": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/DisqualifiedDirector"
                        },
                        "description": "The array of search results"
                    },
                    "pageSize": {
                        "minimum": 0,
                        "type": "integer",
                        "description": "The number of results/items returned per page of results"
                    },
                    "currentPage": {
                        "minimum": 0,
                        "type": "integer",
                        "description": "The page in the collection. Note that it starts at 0"
                    }
                },
                "description": "Paged collection of disqualified directors."
            },
            "Address": {
                "required": [
                    "addressLines"
                ],
                "properties": {
                    "addressLines": {
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "description": "Array of free format address lines.  There are typically 3 addressLines but this is not enforced."
                    },
                    "postCode": {
                        "type": "string",
                        "description": "Post Code",
                        "example": "1025"
                    },
                    "countryCode": {
                        "type": "string",
                        "description": "(2 letter) ISO Country Code",
                        "example": "NZ"
                    },
                    "pafId": {
                        "type": "string",
                        "description": "The PAF Delivery Point ID (DPID) for the address",
                        "example": "580631"
                    }
                },
                "description": "Address line style type for a postal or physical address."
            }
        },
        "securitySchemes": {
            "apiKeyHeader": {
                "type": "apiKey",
                "name": "Ocp-Apim-Subscription-Key",
                "in": "header"
            },
            "apiKeyQuery": {
                "type": "apiKey",
                "name": "subscription-key",
                "in": "query"
            }
        }
    },
    "security": [
        {
            "apiKeyHeader": []
        },
        {
            "apiKeyQuery": []
        }
    ]
}